# ── API Backend ───────────────────────────────────────────────────────────────
# Local:
VITE_API_URL=http://localhost:8080/api/v1
# Render (reemplazar con URL real del backend en Render):
# VITE_API_URL=https://tu-backend.onrender.com/api/v1

# ── Modo datos ────────────────────────────────────────────────────────────────
# false = consume la API real del backend
# true  = usa datos de prueba locales (sin backend)
VITE_USE_MOCK_DATA=false

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=LuxeStay
VITE_APP_VERSION=1.0.0
