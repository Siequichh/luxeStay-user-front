# ── API Backend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api/v1

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Public Keys (NO el Access Token — ese va solo en el backend). Dos flujos, dos
# credenciales distintas (así lo exige el modelo de cuentas de prueba de MP):
#
# VITE_MP_PUBLIC_KEY → Wallet Brick + redirect Checkout Pro. Obtener iniciando sesión
#   como tu cuenta de prueba tipo VENDEDOR → Tus integraciones → Credenciales de
#   producción. Empieza con "APP_USR-" pero es dinero ficticio, no real.
#
# VITE_MP_TEST_PUBLIC_KEY → Tarjeta (CardForm) + Yape, que dependen de los valores de
#   prueba documentados por MP (111111111/123456, tarjetas de prueba, etc.). Obtener
#   iniciando sesión con tu cuenta REAL de Mercado Pago (no una de prueba) → Tus
#   integraciones → tu app → Credenciales de prueba. Empieza con "TEST-".
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_MP_TEST_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Modo datos ────────────────────────────────────────────────────────────────
# false = consume la API real del backend
# true  = usa datos de prueba locales (sin backend)
VITE_USE_MOCK_DATA=false

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=LuxeStay
VITE_APP_VERSION=1.0.0
